{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Caelestia",
  "author": "Caelestia Engine",
  "themes": [
    {
      "name": "Caelestia Dark",
      "appearance": "dark",
      "style": {
        "accents": [
          "#{{ primary.hex }}",
          "#{{ secondary.hex }}",
          "#{{ tertiary.hex }}"
        ],
        "background.appearance": "opaque",
        "border": "#{{ outlineVariant.hex }}",
        "border.variant": "#{{ outline.hex }}",
        "border.focused": "#{{ primary.hex }}",
        "border.selected": "#{{ primary.hex }}",
        "border.transparent": "#{{ outlineVariant.hex }}40",
        "border.disabled": "#{{ outlineVariant.hex }}60",
        "elevated_surface.background": "#{{ surfaceContainerHigh.hex }}",
        "surface.background": "#{{ surface.hex }}",
        "background": "#{{ background.hex }}",
        "element.background": "#{{ surfaceContainer.hex }}",
        "element.hover": "#{{ surfaceContainerHigh.hex }}",
        "element.active": "#{{ surfaceContainerHighest.hex }}",
        "element.selected": "#{{ secondaryContainer.hex }}",
        "element.disabled": "#{{ surfaceVariant.hex }}",
        "drop_target.background": "#{{ primaryContainer.hex }}80",
        "ghost_element.background": null,
        "ghost_element.hover": "#{{ surfaceContainer.hex }}80",
        "ghost_element.active": "#{{ surfaceContainerHigh.hex }}",
        "ghost_element.selected": "#{{ secondaryContainer.hex }}80",
        "ghost_element.disabled": "#{{ surfaceVariant.hex }}60",
        "text": "#{{ onSurface.hex }}",
        "text.muted": "#{{ onSurfaceVariant.hex }}",
        "text.placeholder": "#{{ onSurfaceVariant.hex }}99",
        "text.disabled": "#{{ onSurface.hex }}60",
        "text.accent": "#{{ primary.hex }}",
        "icon": "#{{ onSurface.hex }}",
        "icon.muted": "#{{ onSurfaceVariant.hex }}",
        "icon.disabled": "#{{ onSurface.hex }}60",
        "icon.placeholder": "#{{ onSurfaceVariant.hex }}80",
        "icon.accent": "#{{ primary.hex }}",
        "status_bar.background": "#{{ surface.hex }}",
        "title_bar.background": "#{{ surface.hex }}",
        "title_bar.inactive_background": "#{{ surfaceDim.hex }}",
        "toolbar.background": "#{{ surfaceContainerLow.hex }}",
        "tab_bar.background": "#{{ surfaceContainer.hex }}",
        "tab.inactive_background": "#{{ surfaceContainerLow.hex }}",
        "tab.active_background": "#{{ surfaceContainerHigh.hex }}",
        "search.match_background": "#{{ tertiaryContainer.hex }}80",
        "panel.background": "#{{ surfaceContainerLow.hex }}",
        "panel.focused_border": "#{{ primary.hex }}",
        "pane.focused_border": "#{{ primary.hex }}",
        "scrollbar.thumb.background": "#{{ onSurfaceVariant.hex }}80",
        "scrollbar.thumb.hover_background": "#{{ onSurfaceVariant.hex }}c0",
        "scrollbar.thumb.border": "#{{ outlineVariant.hex }}40",
        "scrollbar.track.background": "#{{ surfaceContainer.hex }}",
        "scrollbar.track.border": "#{{ outlineVariant.hex }}20",
        "editor.foreground": "#{{ onSurface.hex }}",
        "editor.background": "#{{ surfaceContainerLow.hex }}",
        "editor.gutter.background": "#{{ surfaceContainerLow.hex }}",
        "editor.subheader.background": "#{{ surfaceContainer.hex }}",
        "editor.indent_guide": "#{{ outlineVariant.hex }}60",
        "editor.indent_guide_active": "#{{ outline.hex }}",
        "editor.active_line.background": "#{{ surfaceContainerHigh.hex }}80",
        "editor.highlighted_line.background": "#{{ surfaceContainerHigh.hex }}60",
        "editor.line_number": "#{{ onSurfaceVariant.hex }}",
        "editor.active_line_number": "#{{ primary.hex }}",
        "editor.invisible": "#{{ outlineVariant.hex }}80",
        "editor.wrap_guide": "#{{ outlineVariant.hex }}40",
        "editor.active_wrap_guide": "#{{ outline.hex }}80",
        "editor.document_highlight.read_background": "#{{ primaryContainer.hex }}60",
        "editor.document_highlight.write_background": "#{{ secondaryContainer.hex }}80",
        "terminal.background": "#{{ surfaceContainerLow.hex }}",
        "terminal.foreground": "#{{ onSurface.hex }}",
        "terminal.bright_foreground": "#{{ onSurface.hex }}",
        "terminal.dim_foreground": "#{{ onSurfaceVariant.hex }}",
        "terminal.ansi.black": "#{{ surfaceDim.hex }}",
        "terminal.ansi.bright_black": "#{{ surfaceContainerHigh.hex }}",
        "terminal.ansi.dim_black": "#{{ surface.hex }}",
        "terminal.ansi.red": "#{{ error.hex }}",
        "terminal.ansi.bright_red": "#{{ error.hex }}",
        "terminal.ansi.dim_red": "#{{ onErrorContainer.hex }}",
        "terminal.ansi.green": "#{{ tertiary.hex }}",
        "terminal.ansi.bright_green": "#{{ tertiary.hex }}",
        "terminal.ansi.dim_green": "#{{ onTertiaryContainer.hex }}",
        "terminal.ansi.yellow": "#{{ tertiaryFixedDim.hex }}",
        "terminal.ansi.bright_yellow": "#{{ tertiaryFixed.hex }}",
        "terminal.ansi.dim_yellow": "#{{ onTertiaryFixed.hex }}",
        "terminal.ansi.blue": "#{{ primary.hex }}",
        "terminal.ansi.bright_blue": "#{{ primary.hex }}",
        "terminal.ansi.dim_blue": "#{{ onPrimaryContainer.hex }}",
        "terminal.ansi.magenta": "#{{ secondary.hex }}",
        "terminal.ansi.bright_magenta": "#{{ secondary.hex }}",
        "terminal.ansi.dim_magenta": "#{{ onSecondaryContainer.hex }}",
        "terminal.ansi.cyan": "#{{ primaryFixedDim.hex }}",
        "terminal.ansi.bright_cyan": "#{{ primaryFixed.hex }}",
        "terminal.ansi.dim_cyan": "#{{ onPrimaryFixedVariant.hex }}",
        "terminal.ansi.white": "#{{ onSurface.hex }}",
        "terminal.ansi.bright_white": "#{{ onSurface.hex }}",
        "terminal.ansi.dim_white": "#{{ onSurfaceVariant.hex }}",
        "link_text.hover": "#{{ primary.hex }}",
        "conflict": "#{{ error.hex }}",
        "conflict.background": "#{{ errorContainer.hex }}80",
        "conflict.border": "#{{ onErrorContainer.hex }}",
        "created": "#{{ tertiary.hex }}",
        "created.background": "#{{ tertiaryContainer.hex }}80",
        "created.border": "#{{ onTertiaryContainer.hex }}",
        "deleted": "#{{ error.hex }}",
        "deleted.background": "#{{ errorContainer.hex }}80",
        "deleted.border": "#{{ onErrorContainer.hex }}",
        "error": "#{{ error.hex }}",
        "error.background": "#{{ errorContainer.hex }}",
        "error.border": "#{{ onErrorContainer.hex }}",
        "hidden": "#{{ outlineVariant.hex }}",
        "hidden.border": "#{{ outlineVariant.hex }}60",
        "hint": "#{{ primary.hex }}",
        "hint.background": "#{{ primaryContainer.hex }}80",
        "hint.border": "#{{ onPrimaryContainer.hex }}",
        "ignored": "#{{ onSurfaceVariant.hex }}60",
        "ignored.background": "#{{ surfaceVariant.hex }}40",
        "ignored.border": "#{{ outlineVariant.hex }}40",
        "info": "#{{ primary.hex }}",
        "info.background": "#{{ primaryContainer.hex }}80",
        "info.border": "#{{ onPrimaryContainer.hex }}",
        "modified": "#{{ secondary.hex }}",
        "modified.background": "#{{ secondaryContainer.hex }}80",
        "modified.border": "#{{ onSecondaryContainer.hex }}",
        "predictive": "#{{ onSurfaceVariant.hex }}80",
        "predictive.border": "#{{ outline.hex }}",
        "predictive.background": "#{{ surfaceContainerHighest.hex }}80",
        "renamed": "#{{ secondary.hex }}",
        "renamed.border": "#{{ onSecondaryContainer.hex }}",
        "renamed.background": "#{{ secondaryContainer.hex }}80",
        "success": "#{{ tertiary.hex }}",
        "success.background": "#{{ tertiaryContainer.hex }}80",
        "success.border": "#{{ onTertiaryContainer.hex }}",
        "unreachable": "#{{ onSurfaceVariant.hex }}60",
        "unreachable.background": "#{{ surfaceVariant.hex }}40",
        "unreachable.border": "#{{ outlineVariant.hex }}60",
        "warning": "#{{ tertiaryFixedDim.hex }}",
        "warning.background": "#{{ tertiaryContainer.hex }}80",
        "warning.border": "#{{ onTertiaryContainer.hex }}",
        "players": [
          {
            "cursor": "#{{ primary.hex }}",
            "background": "#{{ primaryContainer.hex }}80",
            "selection": "#{{ primaryContainer.hex }}60"
          },
          {
            "cursor": "#{{ secondary.hex }}",
            "background": "#{{ secondaryContainer.hex }}80",
            "selection": "#{{ secondaryContainer.hex }}60"
          }
        ],
        "syntax": {
          "boolean": {
            "color": "#{{ tertiary.hex }}",
            "font_style": null,
            "font_weight": null
          },
          "comment": {
            "color": "#{{ onSurfaceVariant.hex }}",
            "font_style": "italic",
            "font_weight": null
          },
          "comment.doc": {
            "color": "#{{ onSurfaceVariant.hex }}",
            "font_style": "italic",
            "font_weight": null
          },
          "constant": {
            "color": "#{{ tertiary.hex }}",
            "font_style": null,
            "font_weight": null
          },
          "constructor": {
            "color": "#{{ primaryFixed.hex }}",
            "font_style": null,
            "font_weight": null
          },
          "emphasis": {
            "color": "#{{ primary.hex }}",
            "font_style": "italic",
            "font_weight": null
          },
          "emphasis.strong": {
            "color": "#{{ primary.hex }}",
            "font_style": null,
            "font_weight": 700
          },
          "function": {
            "color": "#{{ primary.hex }}",
            "font_style": null,
            "font_weight": null
          },
          "keyword": {
            "color": "#{{ primary.hex }}",
            "font_style": null,
            "font_weight": null
          },
          "number": {
            "color": "#{{ tertiary.hex }}",
            "font_style": null,
            "font_weight": null
          },
          "operator": {
            "color": "#{{ secondary.hex }}",
            "font_style": null,
            "font_weight": null
          },
          "property": {
            "color": "#{{ onBackground.hex }}",
            "font_style": null,
            "font_weight": null
          },
          "punctuation": {
            "color": "#{{ onSurfaceVariant.hex }}",
            "font_style": null,
            "font_weight": null
          },
          "punctuation.bracket": {
            "color": "#{{ onSurfaceVariant.hex }}",
            "font_style": null,
            "font_weight": null
          },
          "punctuation.delimiter": {
            "color": "#{{ onSurfaceVariant.hex }}",
            "font_style": null,
            "font_weight": null
          },
          "punctuation.list_marker": {
            "color": "#{{ secondary.hex }}",
            "font_style": null,
            "font_weight": null
          },
          "punctuation.special": {
            "color": "#{{ secondary.hex }}",
            "font_style": null,
            "font_weight": null
          },
          "string": {
            "color": "#{{ primary.hex }}",
            "font_style": null,
            "font_weight": null
          },
          "string.escape": {
            "color": "#{{ tertiaryContainer.hex }}",
            "font_style": null,
            "font_weight": null
          },
          "string.regex": {
            "color": "#{{ tertiaryContainer.hex }}",
            "font_style": null,
            "font_weight": null
          },
          "string.special": {
            "color": "#{{ primaryFixed.hex }}",
            "font_style": null,
            "font_weight": null
          },
          "string.special.symbol": {
            "color": "#{{ error.hex }}",
            "font_style": null,
            "font_weight": null
          },
          "tag": {
            "color": "#{{ primary.hex }}",
            "font_style": null,
            "font_weight": null
          },
          "text.literal": {
            "color": "#{{ onTertiaryContainer.hex }}",
            "font_style": null,
            "font_weight": null
          },
          "type": {
            "color": "#{{ secondary.hex }}",
            "font_style": null,
            "font_weight": null
          },
          "variable": {
            "color": "#{{ onBackground.hex }}",
            "font_style": null,
            "font_weight": null
          },
          "variable.special": {
            "color": "#{{ error.hex }}",
            "font_style": null,
            "font_weight": null
          }
        }
      }
    }
  ]
}
